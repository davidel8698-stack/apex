{
  "version": "v7",
  "design_principle": "Target 50-60% utilization. R2: coding quality degrades above 70%.",
  "zones": {
    "stable_prefix": {
      "budget_tokens": 30000,
      "contents": ["CLAUDE.md", "SPEC.md summary", "STATE.json", "PLAN_META.json"],
      "policy": "Always loaded. Never evicted."
    },
    "task_context": {
      "budget_tokens": 50000,
      "contents": ["Current phase plan", "Task instructions", "Relevant source files"],
      "policy": "Loaded per-task. Evicted on task completion."
    },
    "working_memory": {
      "budget_tokens": 60000,
      "contents": ["Tool outputs", "Agent responses", "Intermediate results"],
      "policy": "Observation masking after task. Compact on threshold.",
      "masking_rule": "delete_after_n_turns",
      "masking_window_turns": 3
    },
    "generation_reserve": {
      "budget_tokens": 60000,
      "contents": ["Model output generation space"],
      "policy": "Reserved. Never allocate for input."
    }
  },
  "thresholds": {
    "target_utilization_pct": 55,
    "proactive_compact_pct": 55,
    "hard_rotate_pct": 70,
    "never_exceed_pct": 75
  },
  "rotation_triggers": [
    {"type": "utilization_pct", "value": 70, "action": "hard_rotate"},
    {"type": "utilization_pct", "value": 55, "action": "proactive_compact"},
    {"type": "phase_boundary", "action": "proactive_compact"},
    {"type": "task_batch", "value": 6, "action": "warn_and_compact"},
    {"type": "time_minutes", "value": 40, "action": "warn_and_compact"},
    {"type": "recovery_density", "value": 3, "action": "hard_rotate"},
    {"type": "pattern", "pattern": "repeated_tool_errors", "action": "warn_and_compact"}
  ],
  "per_agent_limits": {
    "planner": {"max_input": 40000, "target_input": 25000},
    "architect": {"max_input": 30000, "target_input": 20000},
    "executor": {"max_input": 30000, "target_input": 20000},
    "critic": {"max_input": 25000, "target_input": 15000},
    "verifier": {"max_input": 20000, "target_input": 12000}
  },
  "context_reduction_priority": [
    "observation_masking",
    "compact_working_memory",
    "evict_completed_task_context",
    "hard_rotate"
  ],
  "capacity_tokens": 200000,
  "profiles": {
    "_doc": "M12 task-type profiles (Phase 12.03). Each profile names the content slices a given task_type should load into the executor prompt and the slices it should EXCLUDE. Architect Step 1.11 assigns task_type per task; next.md loads `profiles[task_type]` merged over `profiles.default` when invoking executor / specialist. See framework/docs/TASK-TYPE-PROFILES.md.",
    "default": {
      "include": ["task_xml", "acceptance_criteria", "spec_excerpts", "files_modified"],
      "exclude": [],
      "preload_modules": []
    },
    "new_code": {
      "_purpose": "Greenfield implementation — needs architecture context + interface contracts.",
      "include": ["architecture_docs", "interface_contracts", "style_guide", "code_examples"],
      "exclude": ["full_implementation_history"],
      "preload_modules": []
    },
    "bug_fix": {
      "_purpose": "Localized correction — needs the failure signal, not the system.",
      "include": ["failing_tests", "stack_traces", "execution_path", "minimal_dependencies"],
      "exclude": ["broad_architecture_docs", "unrelated_modules"],
      "preload_modules": []
    },
    "code_review": {
      "_purpose": "Adversarial review — clean-room contract enforced architecturally; profile reinforces.",
      "include": ["spec_excerpts", "diff", "test_results", "surrounding_functions"],
      "exclude": ["implementer_reasoning", "executor_summary_md"],
      "preload_modules": []
    },
    "refactor": {
      "_purpose": "Shape-preserving change — needs the dependency graph and impact surface.",
      "include": ["dependency_graph", "impact_set", "current_tests"],
      "exclude": ["unrelated_files", "broad_architecture_docs"],
      "preload_modules": []
    },
    "test_writing": {
      "_purpose": "Test authoring — needs implementation contracts and the test-architect TEST_PLAN.",
      "include": ["impl_contracts", "test_conventions", "existing_tests", "coverage_report"],
      "exclude": ["broad_architecture_docs"],
      "preload_modules": ["test-architect"]
    },
    "frontend": {
      "_purpose": "UI work — design context + component hierarchy + style guide; backend excluded.",
      "include": ["design_context", "component_hierarchy", "style_guide", "design_tokens"],
      "exclude": ["backend_modules", "database_schema", "infra_config"],
      "preload_modules": ["apex-frontend"]
    }
  },
  "auto_continuity": {
    "_doc": "v7.1 Auto-Continuity Layer — autonomous session continuity for unbounded long-running APEX projects. All fields optional with documented defaults.",
    "bun_memory_threshold_mb": 2048,
    "bun_memory_warn_pct": 70,
    "bun_memory_debounce_samples": 3,
    "memory_sample_interval_seconds": 30,
    "turn_checkpoint_interval": 5,
    "turn_checkpoint_freshness_minutes": 30,
    "session_auto_resume": true,
    "decision_gate_default_action_minutes": 10,
    "decision_gate_default_action": "pause",
    "max_consecutive_auto_pauses": 3,
    "auto_pause_cooldown_minutes": 10
  }
}
