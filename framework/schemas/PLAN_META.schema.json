{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "apex/schemas/PLAN_META.schema.json",
  "title": "APEX PLAN_META.json (v7)",
  "description": "Structured metadata for a phase plan: tasks with spec_ref, verify_level, done_criteria, edge_cases, dependencies, and wave assignment. [שיפור 21, שיפור 39]",
  "type": "object",
  "additionalProperties": false,
  "required": ["phase_id", "phase_name", "tasks"],
  "properties": {
    "phase_id": { "type": "string" },
    "phase_name": { "type": "string" },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "spec_ref",
          "complexity",
          "specialist",
          "is_irreversible",
          "has_behavior",
          "verify_level",
          "files",
          "verify_commands",
          "done_criteria",
          "edge_cases",
          "silent_failure_risks",
          "dependencies",
          "wave",
          "originating_requirement_id"
        ],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "spec_ref": { "type": "array", "items": { "type": "string" } },
          "complexity": { "type": "string" },
          "specialist": { "type": "string" },
          "is_irreversible": { "type": "boolean" },
          "has_behavior": { "type": "boolean" },
          "verify_level": { "type": "string" },
          "files": { "type": "array", "items": { "type": "string" } },
          "verify_commands": { "type": "array", "items": { "type": "string" } },
          "done_criteria": { "type": "array", "items": { "type": "string" } },
          "edge_cases": { "type": "array", "items": { "type": "string" } },
          "silent_failure_risks": { "type": "array", "items": { "type": "string" } },
          "dependencies": { "type": "array", "items": { "type": "string" } },
          "wave": { "type": "integer", "minimum": 1 },
          "originating_requirement_id": { "type": "string", "description": "Unique requirement ID (REQ-NNN) from SPEC.md that this task traces to" },
          "decision_mode": { "type": "string", "enum": ["collaborator", "replacement"], "description": "Dual-mode classifier: collaborator for product/irreversible decisions requiring human approval, replacement for autonomous technical decisions [F-005]" },
          "roundtable_needed": { "type": "boolean", "description": "Flag for multi-faceted architectural decisions requiring multi-specialist roundtable session instead of 2-advocate debate [F-010]" }
        }
      }
    }
  }
}
