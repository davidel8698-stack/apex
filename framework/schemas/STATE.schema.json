{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "apex/schemas/STATE.schema.json",
  "title": "APEX STATE.json (v7)",
  "description": "Machine state for an APEX project: pipeline stage, phase/task progress, context tracking, circuit breaker, token usage, autopilot, session metadata, and drift indicators.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project",
    "complexity_level",
    "complexity_name",
    "pipeline",
    "apex_version",
    "current_stage",
    "pre_build_complete",
    "current_phase",
    "current_unit",
    "current_wave",
    "status",
    "reflexion",
    "context",
    "circuit_breaker",
    "snapshots",
    "tokens",
    "health_check",
    "evoscore",
    "comprehension_gates",
    "tdad",
    "phase_tags",
    "stack_skills",
    "autonomy",
    "autopilot",
    "session",
    "phases_total",
    "phases_completed",
    "units_total",
    "units_completed",
    "pending_notifications",
    "dora",
    "lock",
    "spec_version",
    "strict_mode",
    "proposals_mode",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "project": { "type": "string" },
    "complexity_level": { "type": "integer", "minimum": 0, "maximum": 4 },
    "complexity_name": { "type": "string" },
    "pipeline": { "type": "array", "items": { "type": "string" } },
    "apex_version": { "type": "string", "enum": ["v7"] },
    "current_stage": { "type": "string" },
    "pre_build_complete": { "type": "boolean" },
    "current_phase": { "type": ["string", "null"] },
    "current_unit": { "type": ["string", "null"] },
    "current_wave": { "type": ["integer", "null"] },
    "status": { "type": "string" },
    "reflexion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current_unit_attempts", "max_attempts", "last_reflexion_summary"],
      "properties": {
        "current_unit_attempts": { "type": "integer", "minimum": 0 },
        "max_attempts": { "type": "integer", "minimum": 1 },
        "last_reflexion_summary": { "type": ["string", "null"] }
      }
    },
    "autonomy": {
      "type": "object",
      "description": "Per-verify-level autonomy ladder tracking",
      "required": ["by_verify_level"],
      "additionalProperties": false,
      "properties": {
        "by_verify_level": {
          "type": "object",
          "required": ["A", "B", "C", "D"],
          "additionalProperties": false,
          "properties": {
            "A": {
              "type": "object",
              "additionalProperties": false,
              "required": ["level", "consecutive_successes"],
              "properties": {
                "level": { "type": "integer", "minimum": 0, "maximum": 3 },
                "consecutive_successes": { "type": "integer", "minimum": 0 }
              }
            },
            "B": {
              "type": "object",
              "additionalProperties": false,
              "required": ["level", "consecutive_successes"],
              "properties": {
                "level": { "type": "integer", "minimum": 0, "maximum": 3 },
                "consecutive_successes": { "type": "integer", "minimum": 0 }
              }
            },
            "C": {
              "type": "object",
              "additionalProperties": false,
              "required": ["level", "consecutive_successes"],
              "properties": {
                "level": { "type": "integer", "minimum": 0, "maximum": 3 },
                "consecutive_successes": { "type": "integer", "minimum": 0 }
              }
            },
            "D": {
              "type": "object",
              "additionalProperties": false,
              "required": ["level", "consecutive_successes"],
              "properties": {
                "level": { "type": "integer", "minimum": 0, "maximum": 3 },
                "consecutive_successes": { "type": "integer", "minimum": 0 }
              }
            }
          }
        }
      }
    },
    "evoscore": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "regression_rate",
        "phases_with_regressions",
        "total_cross_phase_tests",
        "last_full_audit"
      ],
      "properties": {
        "regression_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "phases_with_regressions": { "type": "array", "items": { "type": "string" } },
        "total_cross_phase_tests": { "type": "integer", "minimum": 0 },
        "last_full_audit": { "type": ["string", "null"] }
      }
    },
    "comprehension_gates": {
      "type": "object",
      "required": ["current_gate_required"],
      "properties": {
        "current_gate_required": { "type": ["string", "null"] }
      },
      "additionalProperties": { "type": "boolean" }
    },
    "tdad": {
      "type": "object",
      "additionalProperties": false,
      "required": ["index_built", "last_indexed", "total_nodes"],
      "properties": {
        "index_built": { "type": "boolean" },
        "last_indexed": { "type": ["string", "null"], "format": "date-time" },
        "total_nodes": { "type": "integer", "minimum": 0 }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "current_session_phase",
        "session_start_time",
        "estimated_context_usage_pct",
        "last_compact",
        "observation_masking_active",
        "rotation_history"
      ],
      "properties": {
        "current_session_phase": { "type": ["string", "null"] },
        "session_start_time": { "type": "string", "format": "date-time" },
        "estimated_context_usage_pct": { "type": "number", "minimum": 0, "maximum": 100 },
        "last_compact": { "type": ["string", "null"], "format": "date-time" },
        "observation_masking_active": { "type": "boolean" },
        "rotation_history": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["phase", "session_ended", "reason"],
            "properties": {
              "phase": { "type": "string" },
              "session_ended": { "type": "string", "format": "date-time" },
              "reason": { "type": "string" }
            }
          }
        }
      }
    },
    "tokens": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_input",
        "total_output",
        "framework_overhead",
        "overhead_pct",
        "by_phase",
        "by_agent",
        "by_task",
        "productive"
      ],
      "properties": {
        "total_input": { "type": "integer", "minimum": 0 },
        "total_output": { "type": "integer", "minimum": 0 },
        "framework_overhead": { "type": "integer", "minimum": 0 },
        "overhead_pct": { "type": "number", "minimum": 0 },
        "by_phase": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "calls": { "type": "integer", "minimum": 0 },
              "tokens": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "by_agent": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "calls": { "type": "integer", "minimum": 0 },
              "tokens": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "by_task": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "calls": { "type": "integer", "minimum": 0 },
              "tokens": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "productive": { "type": "integer", "minimum": 0 }
      }
    },
    "phase_tags": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "pending_notifications": { "type": "array", "items": { "type": "string" } },
    "stack_skills": { "type": "array", "items": { "type": "string" } },
    "circuit_breaker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "consecutive_no_change_actions",
        "max_allowed",
        "total_tool_calls_this_task",
        "max_tool_calls_per_task",
        "last_file_hash",
        "triggered",
        "trigger_reason"
      ],
      "properties": {
        "consecutive_no_change_actions": { "type": "integer", "minimum": 0 },
        "max_allowed": { "type": "integer", "minimum": 1 },
        "total_tool_calls_this_task": { "type": "integer", "minimum": 0 },
        "max_tool_calls_per_task": { "type": "integer", "minimum": 1 },
        "last_file_hash": { "type": ["string", "null"] },
        "triggered": { "type": "boolean" },
        "trigger_reason": { "type": ["string", "null"] }
      }
    },
    "snapshots": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pre_task_stash", "last_snapshot_task"],
      "properties": {
        "pre_task_stash": { "type": ["string", "null"] },
        "last_snapshot_task": { "type": ["string", "null"] }
      }
    },
    "autopilot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "mode",
        "enabled_at",
        "stop_at_task",
        "start_at_task",
        "range_start",
        "range_end",
        "auto_pause_on",
        "max_tasks_before_human_check",
        "max_phases_before_human_check",
        "paused_reason",
        "was_autopilot",
        "consecutive_sessions",
        "tasks_completed_in_autopilot",
        "previous_tasks_completed_in_autopilot",
        "phases_completed_in_autopilot",
        "last_completed_task",
        "previous_last_completed_task",
        "last_healthy_tag",
        "advisor_last_run",
        "advisor_risk_score"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "mode": { "type": ["string", "null"] },
        "enabled_at": { "type": ["string", "null"], "format": "date-time" },
        "stop_at_task": { "type": ["string", "null"] },
        "start_at_task": { "type": ["string", "null"] },
        "range_start": { "type": ["string", "null"] },
        "range_end": { "type": ["string", "null"] },
        "auto_pause_on": {
          "type": "array",
          "items": { "type": "string" }
        },
        "max_tasks_before_human_check": { "type": "integer", "minimum": 1 },
        "max_phases_before_human_check": { "type": "integer", "minimum": 1 },
        "paused_reason": { "type": ["string", "null"] },
        "was_autopilot": { "type": "boolean" },
        "consecutive_sessions": { "type": "integer", "minimum": 0 },
        "tasks_completed_in_autopilot": { "type": "integer", "minimum": 0 },
        "previous_tasks_completed_in_autopilot": { "type": "integer", "minimum": 0 },
        "phases_completed_in_autopilot": { "type": "integer", "minimum": 0 },
        "last_completed_task": { "type": ["string", "null"] },
        "previous_last_completed_task": { "type": ["string", "null"] },
        "last_healthy_tag": { "type": ["string", "null"] },
        "advisor_last_run": { "type": ["string", "null"], "format": "date-time" },
        "advisor_risk_score": { "type": ["number", "null"] }
      }
    },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "started_at",
        "tasks_completed",
        "tasks_failed",
        "tasks_partial",
        "consecutive_failures",
        "consecutive_partials",
        "last_checkpoint_tag",
        "last_checkpoint_at",
        "last_wave_tag",
        "tasks_since_last_rotation",
        "total_context_rotations",
        "health_status",
        "auto_paused",
        "auto_pause_reason",
        "drift_indicators"
      ],
      "properties": {
        "id": { "type": "string" },
        "started_at": { "type": "string", "format": "date-time" },
        "tasks_completed": { "type": "integer", "minimum": 0 },
        "tasks_failed": { "type": "integer", "minimum": 0 },
        "tasks_partial": { "type": "integer", "minimum": 0 },
        "consecutive_failures": { "type": "integer", "minimum": 0 },
        "consecutive_partials": { "type": "integer", "minimum": 0 },
        "last_checkpoint_tag": { "type": ["string", "null"] },
        "last_checkpoint_at": { "type": ["string", "null"], "format": "date-time" },
        "last_wave_tag": { "type": ["string", "null"] },
        "tasks_since_last_rotation": { "type": "integer", "minimum": 0 },
        "total_context_rotations": { "type": "integer", "minimum": 0 },
        "health_status": {
          "type": "string",
          "enum": ["green", "yellow", "red"]
        },
        "auto_paused": { "type": "boolean" },
        "auto_pause_reason": { "type": ["string", "null"] },
        "last_time_gate": { "type": ["string", "null"], "format": "date-time" },
        "drift_indicators": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "spec_drift_count",
            "circuit_breaker_triggers",
            "reflexion_total_attempts",
            "low_confidence_results"
          ],
          "properties": {
            "spec_drift_count": { "type": "integer", "minimum": 0 },
            "circuit_breaker_triggers": { "type": "integer", "minimum": 0 },
            "reflexion_total_attempts": { "type": "integer", "minimum": 0 },
            "low_confidence_results": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "health_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["last_run", "all_passed", "failed_agents", "test_count"],
      "properties": {
        "last_run": { "type": ["string", "null"] },
        "all_passed": { "type": "boolean" },
        "failed_agents": { "type": "array", "items": { "type": "string" } },
        "test_count": { "type": "integer", "minimum": 0 }
      }
    },
    "dora": {
      "type": "object",
      "description": "DORA self-monitoring metrics for engineering delivery tracking",
      "additionalProperties": false,
      "required": ["lead_time_avg", "deployment_freq", "change_failure_rate", "recovery_time_avg", "phases_failed", "_last_failure_at", "last_updated"],
      "properties": {
        "lead_time_avg": { "type": ["number", "null"], "description": "Average lead time in hours from phase start to phase completion" },
        "deployment_freq": { "type": ["number", "null"], "description": "Phases completed per day (rolling average)" },
        "change_failure_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1, "description": "Fraction of phases that required revert or re-execution" },
        "recovery_time_avg": { "type": ["number", "null"], "description": "Average hours from failure detection to recovery" },
        "phases_failed": { "type": "integer", "minimum": 0, "description": "Total number of phases that failed (for change_failure_rate computation)" },
        "_last_failure_at": { "type": ["string", "null"], "format": "date-time", "description": "Transient timestamp of last failure for recovery_time_avg computation. Cleared after recovery." },
        "last_updated": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "mutation_scores": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "self_heal": {
      "type": "object",
      "description": "Optional state for /apex:self-heal framework gap-closure loop. Initialized lazily by the orchestrator on first invocation; absent in projects that never run the self-heal loop.",
      "additionalProperties": false,
      "required": [
        "status",
        "current_round",
        "current_step",
        "current_wave",
        "consecutive_clean_rounds",
        "max_rounds",
        "last_p01_count",
        "started_at",
        "last_round_artifacts"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["idle", "running", "paused", "closed", "halted"],
          "description": "idle = not started or finished cleanly; running = mid-pipeline; paused = context-rotation pause awaiting /apex:resume; closed = two-clean-rounds convergence reached; halted = max_rounds cap or DIVERGING trajectory escalation."
        },
        "current_round": { "type": "integer", "minimum": 0 },
        "current_step": {
          "type": ["string", "null"],
          "enum": ["audit", "plan", "schedule", "execute", "check", "done", null]
        },
        "current_wave": { "type": ["integer", "null"], "minimum": 0 },
        "consecutive_clean_rounds": { "type": "integer", "minimum": 0 },
        "max_rounds": { "type": "integer", "minimum": 1 },
        "last_p01_count": { "type": ["integer", "null"], "minimum": 0 },
        "started_at": { "type": ["string", "null"], "format": "date-time" },
        "last_round_artifacts": {
          "type": ["array", "null"],
          "items": { "type": "string" },
          "description": "Filenames produced by the most recently completed round, for /apex:status surfacing."
        }
      }
    },
    "phases_total": { "type": "integer", "minimum": 0 },
    "phases_completed": { "type": "integer", "minimum": 0 },
    "units_total": { "type": "integer", "minimum": 0 },
    "units_completed": { "type": "integer", "minimum": 0 },
    "lock": { "type": ["string", "null"] },
    "spec_version": { "type": "string", "description": "SHA256 hash of SPEC.md content for drift detection" },
    "strict_mode": { "type": "boolean", "description": "When true, forces maximum verification (verify_level D) on all tasks" },
    "proposals_mode": { "type": "boolean", "description": "When true, never ask open-ended questions — present numbered proposals with recommended default" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
