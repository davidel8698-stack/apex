{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "apex/schemas/WAVE_MAP.schema.json",
  "title": "APEX WAVE_MAP.json",
  "description": "Pre-computed parallel execution plan generated by architect. Read by execute-phase and /apex:next via WAVE_MAP.waves[N].tasks access pattern.",
  "type": "object",
  "additionalProperties": false,
  "required": ["waves", "generated_from_phase", "generated_at"],
  "properties": {
    "waves": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["wave_number", "tasks"],
        "properties": {
          "wave_number": { "type": "integer", "minimum": 1 },
          "tasks": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          }
        }
      },
      "minItems": 1
    },
    "generated_from_phase": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" }
  }
}
