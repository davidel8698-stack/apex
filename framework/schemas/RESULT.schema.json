{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "apex/schemas/RESULT.schema.json",
  "title": "APEX RESULT.json (v7)",
  "description": "Typed, machine-readable result written by executor for orchestrator and critic. Critic reads ONLY this file — never SUMMARY.md. [שיפור 33]",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "status",
    "files_modified",
    "files_read",
    "tests_run",
    "verify_commands_run",
    "done_criteria_checked",
    "edge_cases_handled",
    "decisions_made",
    "confidence",
    "attempt_number",
    "issues_found",
    "unresolved_risks",
    "spec_sections_referenced",
    "what_next_tasks_can_assume",
    "verified_criteria",
    "unverified_criteria"
  ],
  "properties": {
    "task_id": { "type": "string" },
    "task_start_sha": {
      "type": "string",
      "pattern": "^([0-9a-f]{7,40}|)$",
      "description": "R16-601 (F-601, IMP-001): git HEAD SHA captured by pre-task-snapshot.sh at task start, used by critic STEP 1.5 GIT TRACE VERIFICATION (R16-603) to bound the diff window when verifying that every entry in files_modified[] actually appears in git's view of changes. Pattern accepts a 7-40 hex SHA (typical short or full) OR the empty string when the project has no git history (executor MUST write '' explicitly, never omit, so the required-marker added in R16-601R holds). Additive in R16-601; promoted to required[] in R16-601R after R16-602 executor population lands."
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "failure",
        "partial",
        "gave_up",
        "stuck_on_recurring_error",
        "answer_thrashing",
        "apology_no_completion"
      ],
      "description": "R16-606 (F-606, IMP-063/064/065/007): widened from the original 3 values (success/failure/partial) to add four mythos-grade outcomes consumers (round-checker R16-637, verifier R16-638, executor outcome classifier R16-607, circuit-breaker R16-605) must distinguish: `gave_up` — executor abandoned task without completing required work (semantically separate from `failure` which implies attempted-and-failed); `stuck_on_recurring_error` — circuit-breaker detected the same error hash repeating beyond threshold; `answer_thrashing` — executor flipped between answers on a deterministic question (R2-C091 signal); `apology_no_completion` — output contains apology language with no actual completion. Additive widening — original three members preserved verbatim per acceptance criterion."
    },
    "files_modified": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "action"],
        "properties": {
          "path": { "type": "string" },
          "action": { "type": "string", "enum": ["created", "modified", "deleted"] }
        }
      }
    },
    "files_read": { "type": "array", "items": { "type": "string" } },
    "tests_run": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "result", "output"],
        "properties": {
          "name": { "type": "string" },
          "result": { "type": "string", "enum": ["pass", "fail"] },
          "output": { "type": "string" }
        }
      }
    },
    "verify_commands_run": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "exit_code", "output"],
        "properties": {
          "command": { "type": "string" },
          "exit_code": { "type": "integer" },
          "output": { "type": "string" }
        }
      }
    },
    "done_criteria_checked": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["criterion", "verified", "evidence"],
        "properties": {
          "criterion": { "type": "string" },
          "verified": { "type": "boolean" },
          "evidence": { "type": "string" }
        }
      }
    },
    "edge_cases_handled": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case", "handled", "how"],
        "properties": {
          "case": { "type": "string" },
          "handled": { "type": "boolean" },
          "how": { "type": "string" }
        }
      }
    },
    "decisions_made": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["decision", "rationale", "spec_ref"],
        "properties": {
          "decision": { "type": "string" },
          "rationale": { "type": "string" },
          "spec_ref": { "type": "string" }
        }
      }
    },
    "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
    "attempt_number": { "type": "integer", "minimum": 1 },
    "issues_found": { "type": "array", "items": { "type": "string" } },
    "unresolved_risks": { "type": "array", "items": { "type": "string" } },
    "spec_sections_referenced": { "type": "array", "items": { "type": "string" } },
    "what_next_tasks_can_assume": { "type": "string" },
    "verified_criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["criterion", "evidence"],
        "properties": {
          "criterion": { "type": "string" },
          "evidence": { "type": "string" }
        }
      }
    },
    "unverified_criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["criterion", "reason"],
        "properties": {
          "criterion": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    }
  }
}
