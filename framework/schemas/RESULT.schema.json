{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "apex/schemas/RESULT.schema.json",
  "title": "APEX RESULT.json (v7)",
  "description": "Typed, machine-readable result written by executor for orchestrator and critic. Critic reads ONLY this file — never SUMMARY.md. [שיפור 33]",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "status",
    "files_modified",
    "files_read",
    "tests_run",
    "verify_commands_run",
    "done_criteria_checked",
    "edge_cases_handled",
    "decisions_made",
    "confidence",
    "attempt_number",
    "issues_found",
    "unresolved_risks",
    "spec_sections_referenced",
    "what_next_tasks_can_assume"
  ],
  "properties": {
    "task_id": { "type": "string" },
    "status": { "type": "string", "enum": ["success", "failure", "partial"] },
    "files_modified": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "action"],
        "properties": {
          "path": { "type": "string" },
          "action": { "type": "string", "enum": ["created", "modified", "deleted"] }
        }
      }
    },
    "files_read": { "type": "array", "items": { "type": "string" } },
    "tests_run": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "result", "output"],
        "properties": {
          "name": { "type": "string" },
          "result": { "type": "string", "enum": ["pass", "fail"] },
          "output": { "type": "string" }
        }
      }
    },
    "verify_commands_run": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "exit_code", "output"],
        "properties": {
          "command": { "type": "string" },
          "exit_code": { "type": "integer" },
          "output": { "type": "string" }
        }
      }
    },
    "done_criteria_checked": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["criterion", "verified", "evidence"],
        "properties": {
          "criterion": { "type": "string" },
          "verified": { "type": "boolean" },
          "evidence": { "type": "string" }
        }
      }
    },
    "edge_cases_handled": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case", "handled", "how"],
        "properties": {
          "case": { "type": "string" },
          "handled": { "type": "boolean" },
          "how": { "type": "string" }
        }
      }
    },
    "decisions_made": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["decision", "rationale", "spec_ref"],
        "properties": {
          "decision": { "type": "string" },
          "rationale": { "type": "string" },
          "spec_ref": { "type": "string" }
        }
      }
    },
    "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
    "attempt_number": { "type": "integer", "minimum": 1 },
    "issues_found": { "type": "array", "items": { "type": "string" } },
    "unresolved_risks": { "type": "array", "items": { "type": "string" } },
    "spec_sections_referenced": { "type": "array", "items": { "type": "string" } },
    "what_next_tasks_can_assume": { "type": "string" }
  }
}
