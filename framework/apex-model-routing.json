{
  "_comment": "v7 Model Routing Configuration [R7]. Sonnet achieves 98% of Opus at 1/5 cost. Haiku ~90% of Sonnet at 1/3. resolve_model() in next.md uses exact-name lookup: routing[agent_type].default. Security-specialist is the only agent that defaults to opus (threat-model reasoning requires adversarial depth).",
  "routing": {
    "planner": {
      "default": "sonnet"
    },
    "architect": {
      "default": "sonnet",
      "escalate_on_level": {
        "3": "opus",
        "4": "opus"
      }
    },
    "executor": {
      "default": "sonnet",
      "downgrade_on_verify_level": { "A": "haiku" },
      "escalate_on_level": {
        "4": "opus"
      },
      "escalate_on_retry": "opus"
    },
    "critic": {
      "default": "sonnet",
      "cross_model_required": true,
      "fallback_if_same": "opus"
    },
    "verifier": {
      "default": "sonnet"
    },
    "integration-specialist": {
      "default": "sonnet",
      "escalate_on_level": {
        "4": "opus"
      }
    },
    "security-specialist": {
      "default": "opus"
    },
    "data-specialist": {
      "default": "sonnet",
      "escalate_on_level": {
        "4": "opus"
      }
    },
    "frontend-specialist": {
      "default": "sonnet",
      "escalate_on_level": {
        "4": "opus"
      }
    },
    "test-architect": {
      "default": "haiku",
      "escalate_on_mode": {
        "phase": "sonnet"
      }
    },
    "auditor": {
      "default": "haiku"
    }
  }
}
