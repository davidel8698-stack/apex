{
  "_comment": "v7 Model Routing Configuration [R7] + v8 M04 model diversity [Phase 12.01]. Verification agents (critic/verifier/auditor) default to opus — adversarial review benefits from peak accuracy on small input (~5-10K tokens), and routing executor/architect to sonnet creates the diversity that eliminates shared blind spots (R2-C107 Anthropic +90.2% with Opus-lead+Sonnet-workers; R2-C125). Sonnet achieves 98% of Opus at 1/5 cost. Haiku ~90% of Sonnet at 1/3. resolve_model() in next.md uses exact-name lookup: routing[agent_type].default. See framework/docs/MODEL-ROUTING.md.",
  "routing": {
    "planner": {
      "default": "sonnet"
    },
    "architect": {
      "default": "sonnet",
      "escalate_on_level": {
        "3": "opus",
        "4": "opus"
      }
    },
    "executor": {
      "default": "sonnet",
      "downgrade_on_verify_level": { "A": "haiku" },
      "escalate_on_level": {
        "4": "opus"
      },
      "escalate_on_retry": "opus"
    },
    "critic": {
      "default": "opus",
      "cross_model_required": true,
      "fallback_if_same": "opus"
    },
    "verifier": {
      "default": "opus"
    },
    "integration-specialist": {
      "default": "sonnet",
      "escalate_on_level": {
        "4": "opus"
      }
    },
    "security-specialist": {
      "default": "opus"
    },
    "data-specialist": {
      "default": "sonnet",
      "escalate_on_level": {
        "4": "opus"
      }
    },
    "frontend-specialist": {
      "default": "sonnet",
      "escalate_on_level": {
        "4": "opus"
      }
    },
    "test-architect": {
      "default": "haiku",
      "escalate_on_mode": {
        "phase": "sonnet"
      }
    },
    "auditor": {
      "default": "opus"
    },
    "framework-auditor": {
      "default": "sonnet"
    },
    "remediation-planner": {
      "default": "sonnet"
    },
    "batch-scheduler": {
      "default": "haiku"
    },
    "wave-executor": {
      "default": "sonnet",
      "escalate_on_retry": "opus"
    },
    "round-checker": {
      "default": "sonnet"
    }
  }
}
