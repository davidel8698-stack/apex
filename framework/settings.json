{
  "context_editing": {
    "enabled": false,
    "_doc": "M17 (Phase 12.11) opt-in. When true AND the active adapter exposes the apex_context_editing_supported capability flag, observation-mask.sh routes through the Anthropic Context Editing API (server-side strategy clear_tool_uses_20250919; anthropic-beta: context-management-2025-06-27) for ~84% token reduction on heavy-tool agentic workflows. When false (default) OR capability absent, falls back to R13-002 extractive bash masking (~50% reduction; cross-platform). The two reductions are NOT additive — pick ONE. See framework/docs/CONTEXT-EDITING.md for the decision matrix, failure modes, and SDK version pinning."
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/destructive-guard.sh" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/pre-task-snapshot.sh" }
        ]
      },
      {
        "matcher": "Write|Edit|Agent",
        "hooks": [
          { "type": "command", "command": "if command -v node >/dev/null 2>&1 && [ -f ~/.claude/hooks/apex-prompt-guard.cjs ]; then node ~/.claude/hooks/apex-prompt-guard.cjs; else bash ~/.claude/hooks/prompt-guard.sh; fi" }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/path-guard.sh" }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/owner-guard.sh" }
        ]
      },
      {
        "matcher": "Read|Bash",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/quarantine-guard.sh" }
        ]
      },
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/test-deletion-guard.sh" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/sequence-guard.sh" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/grader-search-guard.sh" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/subagent-guard.sh" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/exfil-guard.sh" }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          { "type": "command", "command": "if command -v node >/dev/null 2>&1 && [ -f ~/.claude/hooks/apex-workflow-guard.cjs ]; then node ~/.claude/hooks/apex-workflow-guard.cjs; else bash ~/.claude/hooks/workflow-guard.sh; fi" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/post-write.sh" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/circuit-breaker.sh" }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/tool-event-logger.sh" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/memory-watchdog.sh" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/turn-checkpoint.sh" }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/schema-drift.sh" }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/ast-kb-check.sh" }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/phantom-check.sh" }
        ]
      },
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/scratchpad-monitor.sh" }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/ci-scan.sh" }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/tdad-index.sh" }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/state-rebuild.sh" }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/session-auto-resume.sh" }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/verify-learnings.sh" }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/tdad-index.sh" }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/pre-compact.sh" }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/subagent-stop.sh" }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/cross-phase-audit.sh" }
        ]
      }
    ]
  }
}
