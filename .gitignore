/apex-learnings.md

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editors
.idea/
.vscode/
*.swp
*~

# Logs
*.log

# Node / Python (defensive — in case skills install deps)
node_modules/
__pycache__/
*.pyc
.venv/
venv/

# Environment
.env
.env.local
.env.*.local

# Detector-sensitivity study labs (see detector-review/EXPERIMENT-PROTOCOL.md)
.lab/

# Ephemeral .apex/ runtime artifacts inside research/lab subdirs
# (framework's own .apex/ files are listed individually above; this catches
#  nested .apex/ dirs created by /apex:* runs inside subprojects)
**/.apex/

# PinScope convergence artifacts ARE tracked (proof-of-process build log)
!pinscope/convergence/
!pinscope/convergence/**
